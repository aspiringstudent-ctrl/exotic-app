VITE_APP_NAME="GridStream Ops"

# Supabase authentication. Leave blank to use local demo mode.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Server-only Supabase ingestion credentials. Never expose service-role keys with VITE_.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
GRIDSTREAM_OWNER_EMAIL=""

# MQTT over WebSocket telemetry source. Leave blank to use the simulator.
VITE_MQTT_URL=""
VITE_MQTT_TOPIC="gridstream/telemetry/#"
VITE_MQTT_USERNAME=""
VITE_MQTT_PASSWORD=""
VITE_MQTT_CLIENT_ID=""

# Optional server-side MQTT overrides for seed/publish/ingest scripts.
MQTT_URL=""
MQTT_TOPIC=""
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_CLIENT_ID=""
MQTT_PUBLISH_INTERVAL_MS="1500"
