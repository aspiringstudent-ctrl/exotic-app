{
  "name": "gridstream-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-ready electrical telemetry monitoring dashboard with simulated streaming data.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "mqtt:publish": "node scripts/publish-random-telemetry.mjs",
    "test": "tsx --test src/domain/telemetry.test.ts src/services/mqttTelemetry.test.ts",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.75.0",
    "lucide-react": "0.468.0",
    "mqtt": "^5.15.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "globals": "15.12.0",
    "supabase": "^2.109.1",
    "tsx": "^4.23.1",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0",
    "vite": "^6.4.3"
  },
  "engines": {
    "node": ">=18.19"
  }
}
